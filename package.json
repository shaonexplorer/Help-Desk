{
  "name": "my-fullstack",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace=server\" \"npm:dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build:client",
    "build:client": "vite build",
    "start": "npm run start --workspace=server"
  },
  "prisma": {
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "shadcn": "^4.11.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "better-auth": "^1.6.20",
    "googleapis": "^173.0.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "resend": "^6.16.0",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  }
}
