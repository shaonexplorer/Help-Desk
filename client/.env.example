# Copy this to .env.development (local) or set in your production deploy.
# All variables MUST be prefixed with VITE_ to be exposed to the client.

# Base URL for the Better Auth server API.
# Empty string ("") = same-origin (uses Vite proxy in dev).
# In production, set to the public origin, e.g. https://api.example.com
VITE_AUTH_BASE_URL=
